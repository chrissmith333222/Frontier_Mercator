# MERIDIAN — Environment Variables Template
# Copy this file to ".env" in the same folder, then fill in your own values.
# NEVER commit the real .env file. NEVER paste its contents into a chat with Claude
# or anyone else — Claude will never ask you to.

# --- ACLED (acleddata.com) ---
# Register at https://acleddata.com/user/re-activate using an institutional/organizational
# email if possible (personal gmail-type addresses get lower access tiers).
# ACLED uses OAuth: you provide email+password here ONCE, and acled_auth.py exchanges
# them for a short-lived access token + refresh token automatically. The access token
# expires every 24 hours, which is why the refresh logic in acled_auth.py exists.
ACLED_EMAIL=your-email@yourorganization.com
ACLED_PASSWORD=your-acled-password
ACLED_CLIENT_ID=acled

# --- ReliefWeb (UN OCHA) ---
# Since 1 Nov 2025, ReliefWeb requires a pre-approved "appname" for all API
# calls — you can't just invent a string. Request one at
# https://apidoc.reliefweb.int/ (short form, reviewed by ReliefWeb staff,
# approval comes by email). See docs/reliefweb_setup.md.
RELIEFWEB_APPNAME=your-approved-appname

# --- Storage / output destination for normalized events ---
# Where acled_normalize.py writes its output. Options: "local" (writes JSON files to
# ./data/normalized/) or "supabase" (writes to a Postgres table via REST API).
MERIDIAN_STORAGE_MODE=local
# Only needed if MERIDIAN_STORAGE_MODE=supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- n8n (only needed if scripts are called from outside n8n for local testing) ---
N8N_WEBHOOK_BASE_URL=

# --- Anthropic (Claude API, for scripts/analysis/reasoning_agent.py) ---
# Console account API key (console.anthropic.com), not a claude.ai subscription
# login. Used only by the local/backend reasoning_agent.py batch script to
# generate cached country assessments -- never called from the deployed
# Streamlit app, so this key never needs to touch Streamlit Cloud.
ANTHROPIC_API_KEY=your-anthropic-console-api-key
# Optional: override the model used for assessments (defaults to claude-sonnet-5)
ANTHROPIC_MODEL=
